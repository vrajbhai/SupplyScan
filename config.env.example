# SupplyScan Environment Config Example
# Rename this to config.env and fill in your keys

# AI Explainer API Keys
# Anthropic Claude API Key (optional, preferred for premium explanations)
CLAUDE_API_KEY=your_claude_api_key_here

# OpenCode Chat Completions API Key (optional, free-tier fallbacks available)
OPENCODE_API_KEY=your_opencode_api_key_here

# AI Explainer Configuration Override
# You can specify which OpenCode model to run (default: north-mini-code-free)
# Supported free models: north-mini-code-free, deepseek-v4-flash-free, mimo-v2.5-free
# OPENCODE_MODEL=north-mini-code-free
